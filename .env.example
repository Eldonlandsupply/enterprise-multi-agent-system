# GitHub Configuration
# GitHub token for API authentication (required for GitHub operations)
GITHUB_TOKEN=your-github-token-here

# GitHub API Configuration
GITHUB_API_BASE_URL=https://api.github.com
GITHUB_API_TIMEOUT=10.0
GITHUB_MAX_RETRIES=3
GITHUB_BACKOFF_FACTOR=0.5

# Queue Configuration
# Rate limiter settings for HTTP requests
RATE_LIMIT_MAX_WORKERS=4
RATE_LIMIT_PER_HOST=1
RATE_LIMIT_BASE_BACKOFF_SECONDS=0.25
RATE_LIMIT_MAX_BACKOFF_SECONDS=30.0
RATE_LIMIT_JITTER_RATIO=0.25

# Logging Configuration
LOG_LEVEL=INFO

# Application Configuration
APP_NAME=enterprise-multi-agent-system
APP_ENV=development
